   "source": [
    "# 🎓 Syllabus Design Agent\n",
    "> **OBE · NBA/NAAC · Revised Bloom's Taxonomy · SDG-Aligned**  \n",
    "> Powered by **Google Gemini** · Free-tier safe (1.5-flash-8b primary)\n",
    "\n",
    "---\n",
    "### ⚡ Quick start\n",
    "1. **Cell 1** — install packages\n",
    "2. **Cell 2** — clone repo + paste your Gemini API key\n",
    "3. **Cell 3** — fill in your course details\n",
    "4. **Cell 4** — generate all 15 sections (streams live, ~5 min)\n",
    "5. **Cell 5** — download the PDF\n",
    "\n",
    "**Free Gemini API key:** https://aistudio.google.com/app/apikey\n",
    "\n",
    "> **If you see a 429 error** — the agent automatically waits and retries,\n",
    "> then tries alternate models (1.5-flash → 2.0-flash → 1.5-pro).  \n",
    "> If all models fail, use **Cell 7** to resume from the failed section."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 1: Install dependencies ──────────────────────────────────\n",
    "!pip install google-genai reportlab python-dotenv rich --quiet\n",
    "print('✅ Dependencies installed')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 2: Clone repo & set Gemini API key ───────────────────────\n",
    "import os, sys\n",
    "\n",
    "REPO = '/content/syllabus-design-agent'\n",
    "if not os.path.exists(REPO):\n",
    "    !git clone https://github.com/mitaoehodaimlai-create/syllabus-design-agent.git {REPO} --quiet\n",
    "    print('✅ Repo cloned')\n",
    "else:\n",
    "    !git -C {REPO} pull --quiet\n",
    "    print('✅ Repo updated')\n",
    "\n",
    "sys.path.insert(0, REPO)\n",
    "\n",
    "from getpass import getpass\n",
    "GEMINI_API_KEY = getpass('🔑 Paste your Gemini API key (input hidden): ')\n",
    "os.environ['GEMINI_API_KEY'] = GEMINI_API_KEY\n",
    "\n",
    "import config\n",
    "print(f'✅ API key set | Primary model: {config.GEMINI_MODEL}')\n",
    "print(f'   Fallback chain: {\" → \".join(config.FALLBACK_MODELS)}')\n",
    "print(f'   Output tokens : {config.MAX_OUTPUT_TOKENS} | Section delay: {config.INTER_SECTION_DELAY}s')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 3: Configure your course ─────────────────────────────────\n",
    "# ✏️  Edit the values below for your course then run this cell\n",
    "\n",
    "from models import CourseInput\n",
    "\n",
    "course = CourseInput(\n",
    "    course_title            = 'Machine Learning',      # ← required\n",
    "    course_code             = 'CS-601',\n",
    "    class_year              = 'TY',                    # FY / SY / TY / B.Tech / M.Tech\n",
    "    department              = 'Computer Engineering',\n",
    "    program                 = 'B.Tech',\n",
    "    discipline              = 'Computer Engineering',\n",
    "    university              = 'MIT Academy of Engineering, Pune',\n",
    "    course_type             = 'Hybrid',                # Theory / Lab / Hybrid\n",
    "    lectures_per_week       = 3,\n",
    "    tutorials_per_week      = 1,\n",
    "    practicals_per_week     = 2,\n",
    "    total_credits           = 5,\n",
    "    total_contact_hours     = 60,\n",
    "    num_units               = 5,\n",
    "    semester_duration_weeks = 16,\n",
    "    prerequisites           = 'Linear Algebra, Python Programming',\n",
    "    num_lab_modules         = 5,\n",
    "    num_lab_assignments     = 10,\n",
    "    pso_count               = 3,\n",
    ")\n",
    "\n",
    "print('✅ Course configured:')\n",
    "print(course.summary())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 4: Generate full syllabus (all 15 sections) ──────────────\n",
    "#\n",
    "# 429 handling is automatic:\n",
    "#   • Reads the API's own retryDelay from the error body\n",
    "#   • Falls back to: 1.5-flash → 2.0-flash → 1.5-pro\n",
    "#   • Each finished section is saved immediately\n",
    "#   • If generation fails mid-way, run Cell 7 to resume\n",
    "\n",
    "import os\n",
    "from pathlib import Path\n",
    "from agent import SyllabusAgent, save_full_markdown, _safe_filename\n",
    "from pdf_generator import generate_pdf\n",
    "\n",
    "OUTPUT_DIR = '/content/syllabus_output'\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "print('🚀 Starting generation — streams live below (~5 min total)\\n')\n",
    "print('Each of the 5 section calls has a 30s pause between them.')\n",
    "print('─' * 65)\n",
    "\n",
    "agent    = SyllabusAgent(api_key=os.environ['GEMINI_API_KEY'])\n",
    "sections = agent.generate(course, output_dir=OUTPUT_DIR)\n",
    "\n",
    "md_path  = save_full_markdown(sections, course, OUTPUT_DIR)\n",
    "print(f'\\n✅ Markdown: {md_path}')\n",
    "\n",
    "slug     = _safe_filename(course.course_title)\n",
    "pdf_path = Path(OUTPUT_DIR) / f'{slug}_FULL_SYLLABUS.pdf'\n",
    "meta = {\n",
    "    'Program'    : f'{course.program} — {course.discipline}',\n",
    "    'Department' : course.department,\n",
    "    'Course Code': course.course_code,\n",
    "    'Credits'    : str(course.total_credits),\n",
    "    'L-T-P'      : course.ltp,\n",
    "    'University' : course.university,\n",
    "}\n",
    "generate_pdf(md_path.read_text(), pdf_path, course_title=course.course_title, meta=meta)\n",
    "print(f'✅ PDF:      {pdf_path}  ({pdf_path.stat().st_size:,} bytes)')\n",
    "print('\\n🎉 Done! Run Cell 5 to download.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 5: Download PDF ──────────────────────────────────────────\n",
    "from google.colab import files\n",
    "files.download(str(pdf_path))\n",
    "print(f'📥 {pdf_path.name}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 6 (optional): Download Markdown ──────────────────────────\n",
    "from google.colab import files\n",
    "files.download(str(md_path))\n",
    "print(f'📥 {md_path.name}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELL 7: Resume from a failed section ──────────────────────────\n",
    "# Run this if Cell 4 failed mid-way after all retries were exhausted.\n",
    "# Already-generated sections are saved in OUTPUT_DIR — they won't be re-run.\n",
    "#\n",
    "# Set section_key to the FIRST section that failed:\n",
    "#   core | lesson_plan | lab_strategy | assignments | resources\n",
    "\n",
    "section_key = 'lesson_plan'      # ← change to the failed section\n",
    "\n",
    "from pathlib import Path\n",
    "from agent import _extract_co_unit_context, _safe_filename, save_full_markdown\n",
    "from pdf_generator import generate_pdf\n",
    "import os\n",
    "\n",
    "OUTPUT_DIR = '/content/syllabus_output'\n",
    "slug       = _safe_filename(course.course_title)\n",
    "\n",
    "# Load CO context from already-saved core section\n",
    "core_md = Path(OUTPUT_DIR) / f'{slug}_core.md'\n",
    "co_ctx  = _extract_co_unit_context(core_md.read_text()) if core_md.exists() else ''\n",
    "\n",
    "# Find which sections still need to be generated\n",
    "all_keys  = ['core', 'lesson_plan', 'lab_strategy', 'assignments', 'resources']\n",
    "start_idx = all_keys.index(section_key)\n",
    "remaining = all_keys[start_idx:]\n",
    "print(f'Sections to generate: {remaining}\\n')\n",
    "\n",
    "# Load already-done sections from disk\n",
    "sections = {}\n",
    "for k in all_keys[:start_idx]:\n",
    "    p = Path(OUTPUT_DIR) / f'{slug}_{k}.md'\n",
    "    if p.exists():\n",
    "        sections[k] = p.read_text()\n",
    "        print(f'  Loaded from disk: {k}')\n",
    "\n",
    "# Generate remaining sections\n",
    "for k in remaining:\n",
    "    import prompts\n",
    "    dispatch = {\n",
    "        'core'        : lambda: prompts.core_prompt(course),\n",
    "        'lesson_plan' : lambda: prompts.lesson_plan_prompt(course, co_ctx),\n",
    "        'lab_strategy': lambda: prompts.lab_strategy_assessment_prompt(course, co_ctx),\n",
    "        'assignments' : lambda: prompts.assignments_rubrics_mapping_prompt(course, co_ctx),\n",
    "        'resources'   : lambda: prompts.resources_support_prompt(course, co_ctx),\n",
    "    }\n",
    "    print(f'\\n🔄 Generating: {k}')\n",
    "    text = agent.regenerate_section(k, course, co_ctx)\n",
    "    sections[k] = text\n",
    "    (Path(OUTPUT_DIR) / f'{slug}_{k}.md').write_text(text)\n",
    "    print(f'✅ Saved: {k}')\n",
    "\n",
    "# Re-assemble and export PDF\n",
    "md_path  = save_full_markdown(sections, course, OUTPUT_DIR)\n",
    "pdf_path = Path(OUTPUT_DIR) / f'{slug}_FULL_SYLLABUS.pdf'\n",
    "meta     = {'Program': f'{course.program} — {course.discipline}',\n",
    "            'Credits': str(course.total_credits), 'L-T-P': course.ltp}\n",
    "generate_pdf(md_path.read_text(), pdf_path, course_title=course.course_title, meta=meta)\n",
    "print(f'\\n✅ PDF rebuilt: {pdf_path}')\n",
    "\n",
    "from google.colab import files\n",
    "files.download(str(pdf_path))"
   ]
  }
 ]
}"
